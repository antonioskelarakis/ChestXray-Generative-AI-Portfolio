0), nn.BatchNorm2d(1024), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(1024, 512, 3, 1, 1), nn.BatchNorm2d(512), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(512, 256, 3, 1, 1), nn.BatchNorm2d(256), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(256, 128, 3, 1, 1), nn.BatchNorm2d(128), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(128, 1, 3, 1, 1), nn.Tanh()\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","class Critic(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.main = nn.Sequential(\n","            nn.Conv2d(1, 64, 4, 2, 1), nn.LeakyReLU(0.2),\n","            nn.Conv2d(64, 128, 4, 2, 1), nn.InstanceNorm2d(128, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(128, 256, 4, 2, 1), nn.InstanceNorm2d(256, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(256, 512, 4, 2, 1), nn.InstanceNorm2d(512, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(512, 1, 4, 1, 0)\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","# 4. WGAN-GP GRADIENT PENALTY\n","def compute_gradient_penalty(critic, real_samples, fake_samples):\n","    alpha = torch.rand(real_samples.size(0), 1, 1, 1).to(device)\n","    interpolates = (alpha * real_samples + ((1 - alpha) * fake_samples)).requires_grad_(True)\n","    d_interpolates = critic(interpolates)\n","    fake = torch.ones(d_interpolates.shape).to(device)\n","    gradients = torch.autograd.grad(\n","        outputs=d_interpolates, inputs=interpolates,\n","        grad_outputs=fake, create_graph=True, retain_graph=True, only_inputs=True\n","    )[0]\n","    gradients = gradients.view(gradients.size(0), -1)\n","    gradient_penalty = ((gradients.norm(2, dim=1) - 1) ** 2).mean()\n","    return gradient_penalty\n","\n","# 5. INITIALIZATION\n","gen, critic = Generator().to(device), Critic().to(device)\n","opt_gen = optim.Adam(gen.parameters(), lr=0.00005, betas=(0.0, 0.9))\n","opt_critic = optim.Adam(critic.parameters(), lr=0.00005, betas=(0.0, 0.9))\n","\n","# 6. RESUME FROM CHECKPOINT\n","start_epoch = 1260\n","if os.path.exists(checkpoint_path):\n","    print(f\"🔄 Loading checkpoint: {checkpoint_path}\")\n","    checkpoint = torch.load(checkpoint_path, map_location=device)\n","    gen.load_state_dict(checkpoint['gen_state_dict'])\n","    critic.load_state_dict(checkpoint['critic_state_dict'])\n","    opt_gen.load_state_dict(checkpoint['opt_gen_state_dict'])\n","    opt_critic.load_state_dict(checkpoint['opt_critic_state_dict'])\n","    start_epoch = checkpoint.get('epoch', start_epoch)\n","    print(f\"✅ Resuming from Epoch {start_epoch}\")\n","\n","# 7. DATASET\n","dataset = medmnist.PneumoniaMNIST(split='train', transform=transforms.Compose([\n","    transforms.Resize(64), transforms.ToTensor(), transforms.Normalize((0.5,), (0.5,))\n","]), download=True)\n","loader = DataLoader(dataset, batch_size=32, shuffle=True)\n","\n","# 8. TRAINING LOOP (1:5 RATIO)\n","LAMBDA_GP = 10\n","N_CRITIC = 5\n","\n","tracker = EmissionsTracker(output_dir=save_path, log_level=\"error\")\n","tracker.start()\n","\n","try:\n","    print(f\"🚀 Starting Training Loop to Epoch 1500...\")\n","    for epoch in range(start_epoch, 1501):\n","        for real, _ in loader:\n","            real = real.to(device)\n","            batch_size = real.shape[0]\n","\n","            # (A) Train Critic (5 times)\n","            for _ in range(N_CRITIC):\n","                noise = torch.randn(batch_size, 100, 1, 1).to(device)\n","                fake = gen(noise)\n","                gp = compute_gradient_penalty(critic, real, fake.detach())\n","                loss_d = -(torch.mean(critic(real)) - torch.mean(critic(fake.detach()))) + LAMBDA_GP * gp\n","                critic.zero_grad(); loss_d.backward(); opt_critic.step()\n","\n","            # (B) Train Generator (1 time)\n","            noise = torch.randn(batch_size, 100, 1, 1).to(device)\n","            loss_g = -torch.mean(critic(gen(noise)))\n","            gen.zero_grad(); loss_g.backward(); opt_gen.step()\n","\n","        # Save and Log every 10 epochs\n","        if (epoch + 1) % 10 == 0:\n","            torch.save({\n","                'epoch': epoch + 1,\n","                'gen_state_dict': gen.state_dict(),\n","                'critic_state_dict': critic.state_dict(),\n","                'opt_gen_state_dict': opt_gen.state_dict(),\n","                'opt_critic_state_dict': opt_critic.state_dict(),\n","            }, checkpoint_path)\n","\n","            with open(log_path, 'a') as f:\n","                f.write(f\"{datetime.datetime.now()},{epoch+1},{loss_d.item():.4f},{loss_g.item():.4f}\\n\")\n","\n","            # Save a visual sample\n","            with torch.no_grad():\n","                sample = gen(torch.randn(16, 100, 1, 1).to(device))\n","                utils.save_image(sample, os.path.join(save_path, \"latest_wgan_gp.png\"), normalize=True)\n","\n","            print(f\"📊 Milestone: Epoch {epoch+1} | Loss D: {loss_d.item():.2f} | Loss G: {loss_g.item():.2f}\")\n","\n","except KeyboardInterrupt:\n","    print(\"\\n🛑 Training manually interrupted.\")\n","finally:\n","    tracker.stop()\n","    print(\"✅ Sustainability data saved. Training session closed.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"-QZFSFtQHllQ","outputId":"5be5a43b-988d-4526-eea8-50813b5c4f7c"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","✅ Drive Linked Successfully.\n","🔄 Loading checkpoint: /content/drive/MyDrive/Medical_WGAN_GP_Project/checkpoint_latest.pth\n"]},{"output_type":"stream","name":"stderr","text":["[codecarbon WARNING @ 09:28:53] Multiple instances of codecarbon are allowed to run at the same time.\n"]},{"output_type":"stream","name":"stdout","text":["✅ Resuming from Epoch 1275\n","🚀 Starting Training Loop to Epoch 1500...\n","📊 Milestone: Epoch 128