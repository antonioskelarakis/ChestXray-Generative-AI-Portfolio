            nn.BatchNorm2d(features_g * 8),\n","            nn.ReLU(True),\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(features_g * 8, features_g * 4, 3, 1, 1),\n","            nn.BatchNorm2d(features_g * 4),\n","            nn.ReLU(True),\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(features_g * 4, features_g * 2, 3, 1, 1),\n","            nn.BatchNorm2d(features_g * 2),\n","            nn.ReLU(True),\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(features_g * 2, img_channels, 3, 1, 1),\n","            nn.Tanh(),\n","        )\n","    def forward(self, x): return self.gen(x)\n","\n","class Critic(nn.Module):\n","    def __init__(self, img_channels, features_d):\n","        super(Critic, self).__init__()\n","        # Use Spectral Norm for stability\n","        def sn_conv(in_c, out_c, k, s, p):\n","            return nn.utils.spectral_norm(nn.Conv2d(in_c, out_c, k, s, p))\n","\n","        self.critic = nn.Sequential(\n","            sn_conv(img_channels, features_d, 4, 2, 1),\n","            nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d, features_d * 2, 4, 2, 1),\n","            nn.InstanceNorm2d(features_d * 2, affine=True),\n","            nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d * 2, features_d * 4, 4, 2, 1),\n","            nn.InstanceNorm2d(features_d * 4, affine=True),\n","            nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d * 4, features_d * 8, 4, 2, 1),\n","            nn.InstanceNorm2d(features_d * 8, affine=True),\n","            nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d * 8, 1, 4, 1, 0),\n","        )\n","    def forward(self, x): return self.critic(x)\n","\n","# ==========================================\n","# 3. GRADIENT PENALTY & INITIALIZATION\n","# ==========================================\n","def gradient_penalty(critic, real, fake, device):\n","    BATCH_SIZE, C, H, W = real.shape\n","    alpha = torch.rand((BATCH_SIZE, 1, 1, 1)).repeat(1, C, H, W).to(device)\n","    interpolated = (real * alpha + fake * (1 - alpha)).requires_grad_(True)\n","    mixed_scores = critic(interpolated)\n","    gradient = torch.autograd.grad(\n","        inputs=interpolated, outputs=mixed_scores,\n","        grad_outputs=torch.ones_like(mixed_scores),\n","        create_graph=True, retain_graph=True,\n","    )[0]\n","    gradient = gradient.view(gradient.shape[0], -1)\n","    return torch.mean((gradient.norm(2, dim=1) - 1) ** 2)\n","\n","# Load ChestMNIST (PneumoniaMNIST subset)\n","info = INFO['pneumoniamnist']\n","DataClass = getattr(medmnist, info['python_class'])\n","transform = transforms.Compose([\n","    transforms.Resize(64),\n","    transforms.ToTensor(),\n","    transforms.Normalize((0.5,), (0.5,)),\n","])\n","train_dataset = DataClass(split='train', transform=transform, download=True)\n","loader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True)\n","\n","gen = Generator(Z_DIM, 1, FEATURES).to(device)\n","critic = Critic(1, FEATURES).to(device)\n","opt_gen = optim.Adam(gen.parameters(), lr=LR, betas=(0.0, 0.9))\n","opt_critic = optim.Adam(critic.parameters(), lr=LR, betas=(0.0, 0.9))\n","\n","# ==========================================\n","# 4. CONTINUOUS MONITORING TRAINING LOOP\n","# ==========================================\n","tracker = EmissionsTracker(output_dir=save_path, project_name=\"WGAN-GP_ChestMNIST\")\n","tracker.start()\n","\n","print(\"🚀 Starting WGAN-GP Training with Continuous Monitoring...\")\n","\n","try:\n","    for epoch in range(NUM_EPOCHS):\n","        total_loss_d, total_loss_g = 0, 0\n","\n","        for batch_idx, (real, _) in enumerate(loader):\n","            real = real.to(device)\n","            cur_batch_size = real.shape[0]\n","\n","            # Critic Update\n","            for _ in range(CRITIC_ITERATIONS):\n","                noise = torch.randn(cur_batch_size, Z_DIM, 1, 1).to(device)\n","                fake = gen(noise)\n","                critic_real = critic(real).reshape(-1)\n","                critic_fake = critic(fake).reshape(-1)\n","                gp = gradient_penalty(critic, real, fake, device)\n","                loss_d = -(torch.mean(critic_real) - torch.mean(critic_fake)) + LAMBDA_GP * gp\n","                critic.zero_grad()\n","                loss_d.backward(retain_graph=True)\n","                opt_critic.step()\n","                total_loss_d += loss_d.item()\n","\n","            # Generator Update\n","            gen_fake = critic(fake).reshape(-1)\n","            loss_g = -torch.mean(gen_fake)\n","            gen.zero_grad()\n","            loss_g.backward()\n","            opt_gen.step()\n","            total_loss_g += loss_g.item()\n","\n","        # Log Data per Epoch\n","        avg_loss_d = total_loss_d / (len(loader) * CRITIC_ITERATIONS)\n","        avg_loss_g = total_loss_g / len(loader)\n","        current_emissions = tracker.final_emissions if hasattr(tracker, 'final_emissions') else 0\n","\n","        with open(log_file, 'a', newline='') as f:\n","            writer = csv.writer(f)\n","            writer.writerow([epoch + 1, avg_loss_d, avg_loss_g, current_emissions])\n","\n","        # Every 100 Epochs: Save Images & Model\n","        if (epoch + 1) % 100 == 0:\n","            print(f\"Epoch [{epoch+1}/{NUM_EPOCHS}] | Loss D: {avg_loss_d:.4f} | Loss G: {avg_loss_g:.4f}\")\n","            with torch.no_grad():\n","                gen.eval()\n","                samples = gen(torch.randn(16, Z_DIM, 1, 1).to(device))\n","                utils.save_image(samples, f\"{save_path}/epoch_{epoch+1}.png\", normalize=True, nrow=4)\n","                gen.train()\n","            torch.save(gen.state_dict(), f\"{save_path}/wgan_gen_checkpoint.pth\")\n","\n","finally:\n","    tracker.stop()\n","    print(f\"✅ Training Complete. Logs and images saved to {save_path}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":