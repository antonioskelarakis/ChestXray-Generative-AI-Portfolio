 drive\n","    drive.mount('/content/drive', force_remount=True)\n","    print(\"✅ Drive mounted successfully.\")\n","except Exception as e:\n","    print(f\"⚠️ Drive mount failed: {e}. If not on Colab, ignore this.\")\n","\n","# INSTALLS\n","!pip install -q medmnist codecarbon\n","import medmnist\n","from medmnist import INFO\n","from codecarbon import EmissionsTracker\n","\n","# ==========================================\n","# 2. PATHS & CONFIG\n","# ==========================================\n","save_path = '/content/drive/MyDrive/Medical_GAN_Refined'\n","if not os.path.exists(save_path):\n","    try:\n","        os.makedirs(save_path)\n","    except:\n","        print(\"Folder exists or Drive not accessible. Check your permissions.\")\n","\n","device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","LR = 0.0001\n","BATCH_SIZE = 64\n","Z_DIM = 100\n","NUM_EPOCHS = 1000\n","FEATURES = 64\n","\n","# ==========================================\n","# 3. REFINED ARCHITECTURE (Method 2)\n","# ==========================================\n","\n","class RefinedGenerator(nn.Module):\n","    def __init__(self, z_dim, img_channels, features_g):\n","        super(RefinedGenerator, self).__init__()\n","        self.gen = nn.Sequential(\n","            nn.ConvTranspose2d(z_dim, features_g * 16, 4, 1, 0),\n","            nn.BatchNorm2d(features_g * 16),\n","            nn.ReLU(True),\n","            # Resize-Conv Block 1\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(features_g * 16, features_g * 8, 3, 1, 1),\n","            nn.BatchNorm2d(features_g * 8),\n","            nn.ReLU(True),\n","            # Resize-Conv Block 2\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(features_g * 8, features_g * 4, 3, 1, 1),\n","            nn.BatchNorm2d(features_g * 4),\n","            nn.ReLU(True),\n","            # Resize-Conv Block 3\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(features_g * 4, features_g * 2, 3, 1, 1),\n","            nn.BatchNorm2d(features_g * 2),\n","            nn.ReLU(True),\n","            # Resize-Conv Block 4\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(features_g * 2, img_channels, 3, 1, 1),\n","            nn.Tanh(),\n","        )\n","    def forward(self, x): return self.gen(x)\n","\n","class RefinedCritic(nn.Module):\n","    def __init__(self, img_channels, features_d):\n","        super(RefinedCritic, self).__init__()\n","        def sn_conv(in_c, out_c, k, s, p):\n","            return nn.utils.spectral_norm(nn.Conv2d(in_c, out_c, k, s, p))\n","\n","        self.critic = nn.Sequential(\n","            sn_conv(img_channels, features_d, 4, 2, 1),\n","            nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d, features_d * 2, 4, 2, 1),\n","            nn.InstanceNorm2d(features_d * 2, affine=True),\n","            nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d * 2, features_d * 4, 4, 2, 1),\n","            nn.InstanceNorm2d(features_d * 4, affine=True),\n","            nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d * 4, features_d * 8, 4, 2, 1),\n","            nn.InstanceNorm2d(features_d * 8, affine=True),\n","            nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d * 8, 1, 4, 1, 0),\n","        )\n","    def forward(self, x): return self.critic(x)\n","\n","# ==========================================\n","# 4. INITIALIZATION\n","# ==========================================\n","info = INFO['pneumoniamnist']\n","DataClass = getattr(medmnist, info['python_class'])\n","transform = transforms.Compose([\n","    transforms.Resize(64),\n","    transforms.ToTensor(),\n","    transforms.Normalize((0.5,), (0.5,)),\n","])\n","train_dataset = DataClass(split='train', transform=transform, download=True)\n","loader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True)\n","\n","gen = RefinedGenerator(Z_DIM, 1, FEATURES).to(device)\n","critic = RefinedCritic(1, FEATURES).to(device)\n","opt_gen = optim.Adam(gen.parameters(), lr=LR, betas=(0.5, 0.999))\n","opt_critic = optim.Adam(critic.parameters(), lr=LR, betas=(0.5, 0.999))\n","criterion = nn.BCEWithLogitsLoss()\n","\n","# Checkpoint Handling\n","checkpoint_path = f\"{save_path}/refined_checkpoint_latest.pth\"\n","start_epoch = 0\n","\n","if os.path.exists(checkpoint_path):\n","    print(\"🧠 Checkpoint detected. Resuming...\")\n","    checkpoint = torch.load(checkpoint_path, map_location=device)\n","    gen.load_state_dict(checkpoint['gen_state_dict'])\n","    critic.load_state_dict(checkpoint['critic_state_dict'])\n","    opt_gen.load_state_dict(checkpoint['opt_gen_state_dict'])\n","    opt_critic.load_state_dict(checkpoint['opt_critic_state_dict'])\n","    start_epoch = checkpoint['epoch'] + 1\n","else:\n","    print(\"🆕 Starting fresh 1000-epoch run...\")\n","\n","# ==========================================\n","# 5. TRAINING LOOP\n","# ==========================================\n","tracker = EmissionsTracker(output_dir=save_path)\n","tracker.start()\n","\n","try:\n","    for epoch in range(start_epoch, NUM_EPOCHS):\n","        for batch_idx, (real, _) in enumerate(loader):\n","            real = real.to(device)\n","            cur_batch_size = real.shape[0]\n","\n","            # Train Critic\n","            noise = torch.randn(cur_batch_size, Z_DIM, 1, 1).to(device)\n","            fake = gen(noise)\n","            critic_real = critic(real).reshape(-1)\n","            loss_critic_real = criterion(critic_real, torch.ones_like(critic_real) * 0.9)\n","            critic_fake = critic(fake.detach()).reshape(-1)\n","            loss_critic_fake = criterion(critic_fake, torch.zeros_like(critic_fake))\n","            loss_critic = (loss_critic_real + loss_critic_fake) / 2\n","\n","            critic.zero_grad()\n","            loss_critic.backward()\n","            opt_critic.step()\n","\n","            # Train Generator\n","            output = critic(fake).reshape(-1)\n","            loss_gen = criterion(output, torch.ones_like(output))\n","\n","            gen.zero_grad()\n","            loss_gen.backward()\n","            opt_gen.step()\n","\n","        # Save latest state every epoch\n","        torch.save({\n","            'epoch': epoch,\n","            'gen_state_dict': gen.state_dict(),\n","            'critic_state_dict': critic.state_dict(),\n","            'opt_gen_state_dict': opt_gen.state_dict(),\n","            'opt_critic_state_dict': opt_critic.state_dict(),\n","        }, checkpoint_path)\n","\n","        if (epoch + 1) % 100 == 0:\n","            print(f\"💾 Milestone: Epoch {epoch+1}\")\n","            torch.save(gen.state_dict(), f\"{save_path}/refined_gen_epoch_{epoch+1}.pth\")\n","            with torch.no_grad():\n","                samples = gen(torch.randn(16, Z_DIM, 1, 1).to(device))\n","                utils.save_image(samples, f\"{save_path}/refined_sample_epoch_{epoch+1}.png\", normalize=True)\n","\n","        if (epoch + 1) % 20 == 0:\n","            print(f\"Epoch [{epoch+1}/{NUM_EPOCHS}] Loss D: {loss_critic:.4f}, Loss G: {loss_gen:.4f}\")\n","\n","finally:\n","    tracker.stop()\n","    print(\"✅ Session complete.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"yHEkELKb8alk","outputId":"f5bc14f6-c9dc-49c6-af5f-243a02859884"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","✅ Drive mounted successfully.\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m380.8/380.8 kB\u001b[0m \u001b[31m10.0 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m155.6/155.6 kB\u001b[0m \u001b[31m15.8 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m115.9/115.9 kB\u001b[0m \u001b[31m9.6 MB/s\u001b[0m eta \u001b[36m0:00: