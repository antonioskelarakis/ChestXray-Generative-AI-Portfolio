.png', 'refined_gen_epoch_400.pth', 'refined_sample_epoch_400.png', 'refined_gen_epoch_500.pth', 'refined_sample_epoch_500.png', 'refined_gen_epoch_600.pth', 'refined_sample_epoch_600.png', 'refined_gen_epoch_700.pth', 'refined_sample_epoch_700.png', 'refined_gen_epoch_800.pth', 'refined_sample_epoch_800.png', 'refined_gen_epoch_900.pth', 'refined_sample_epoch_900.png', 'refined_gen_epoch_1000.pth', 'refined_sample_epoch_1000.png', 'emissions.csv', 'refined_checkpoint_latest.pth']\n"]}]},{"cell_type":"code","source":["import os\n","import torch\n","import torch.nn as nn\n","import torch.optim as optim\n","import csv\n","import subprocess\n","import sys\n","from torch.utils.data import DataLoader\n","from torchvision import transforms, utils\n","\n","# 1. INSTALLS & MOUNT\n","try:\n","    from google.colab import drive\n","    drive.mount('/content/drive', force_remount=True)\n","    os.chdir('/content/drive/MyDrive/Medical_GAN_Refined/')\n","    print(f\"✅ Working in: {os.getcwd()}\")\n","except:\n","    print(\"⚠️ Drive mount failed. Ensure you are on Colab.\")\n","\n","def install(package):\n","    subprocess.check_call([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", package])\n","\n","install(\"medmnist\")\n","install(\"codecarbon\")\n","\n","import medmnist\n","from medmnist import INFO\n","from codecarbon import EmissionsTracker\n","\n","# 2. CONFIG\n","csv_log_path = 'loss_history.csv'\n","checkpoint_path = 'refined_checkpoint_latest.pth'\n","device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","NUM_EPOCHS = 1500\n","BATCH_SIZE = 64\n","Z_DIM = 100\n","LR = 0.0001\n","FEATURES = 64\n","\n","# 3. ARCHITECTURE Method 2\n","class RefinedGenerator(nn.Module):\n","    def __init__(self, z_dim, img_channels, features_g):\n","        super(RefinedGenerator, self).__init__()\n","        self.gen = nn.Sequential(\n","            nn.ConvTranspose2d(z_dim, features_g * 16, 4, 1, 0),\n","            nn.BatchNorm2d(features_g * 16), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(features_g * 16, features_g * 8, 3, 1, 1),\n","            nn.BatchNorm2d(features_g * 8), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(features_g * 8, features_g * 4, 3, 1, 1),\n","            nn.BatchNorm2d(features_g * 4), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(features_g * 4, features_g * 2, 3, 1, 1),\n","            nn.BatchNorm2d(features_g * 2), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(features_g * 2, img_channels, 3, 1, 1),\n","            nn.Tanh(),\n","        )\n","    def forward(self, x): return self.gen(x)\n","\n","class RefinedCritic(nn.Module):\n","    def __init__(self, img_channels, features_d):\n","        super(RefinedCritic, self).__init__()\n","        def sn_conv(in_c, out_c, k, s, p): return nn.utils.spectral_norm(nn.Conv2d(in_c, out_c, k, s, p))\n","        self.critic = nn.Sequential(\n","            sn_conv(img_channels, features_d, 4, 2, 1), nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d, features_d * 2, 4, 2, 1), nn.InstanceNorm2d(features_d * 2, affine=True), nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d * 2, features_d * 4, 4, 2, 1), nn.InstanceNorm2d(features_d * 4, affine=True), nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d * 4, features_d * 8, 4, 2, 1), nn.InstanceNorm2d(features_d * 8, affine=True), nn.LeakyReLU(0.2, inplace=True),\n","            sn_conv(features_d * 8, 1, 4, 1, 0),\n","        )\n","    def forward(self, x): return self.critic(x)\n","\n","# 4. INITIALIZATION\n","gen = RefinedGenerator(Z_DIM, 1, FEATURES).to(device)\n","critic = RefinedCritic(1, FEATURES).to(device)\n","opt_gen = optim.Adam(gen.parameters(), lr=LR, betas=(0.5, 0.999))\n","opt_critic = optim.Adam(critic.parameters(), lr=LR, betas=(0.5, 0.999))\n","criterion = nn.BCEWithLogitsLoss()\n","\n","# Load Checkpoint\n","if os.path.exists(checkpoint_path):\n","    print(f\"🧠 Resuming from Epoch {torch.load(checkpoint_path, map_location='cpu')['epoch'] + 1}\")\n","    ckpt = torch.load(checkpoint_path, map_location=device)\n","    gen.load_state_dict(ckpt['gen_state_dict'])\n","    critic.load_state_dict(ckpt['critic_state_dict'])\n","    opt_gen.load_state_dict(ckpt['opt_gen_state_dict'])\n","    opt_critic.load_state_dict(ckpt['opt_critic_state_dict'])\n","    start_epoch = ckpt['epoch'] + 1\n","else:\n","    start_epoch = 0\n","    print(\"🆕 No checkpoint found. Starting fresh.\")\n","\n","# Data\n","info = INFO['pneumoniamnist']\n","DataClass = getattr(medmnist, info['python_class'])\n","transform = transforms.Compose([transforms.Resize(64), transforms.ToTensor(), transforms.Normalize((0.5,), (0.5,))])\n","loader = DataLoader(DataClass(split='train', transform=transform, download=True), batch_size=BATCH_SIZE, shuffle=True)\n","\n","# 5. LOGGING HELPERS\n","def record_to_ledger(epoch, loss_d, loss_g):\n","    file_exists = os.path.isfile(csv_log_path)\n","    with open(csv_log_path, 'a', newline='') as f:\n","        writer = csv.writer(f)\n","        if not file_exists: writer.writerow(['epoch', 'loss_d', 'loss_g'])\n","        writer.writerow([epoch, loss_d, loss_g])\n","\n","# 6. TRAINING LOOP\n","tracker = EmissionsTracker(output_dir=\".\", project_name=\"GAN_1500_Final\")\n","tracker.start()\n","\n","try:\n","    for epoch in range(start_epoch, NUM_EPOCHS):\n","        d_losses, g_losses = [], []\n","        for real, _ in loader:\n","            real = real.to(device)\n","            bs = real.size(0)\n","\n","            # Critic Update\n","            noise = torch.randn(bs, Z_DIM, 1, 1, device=device)\n","            fake = gen(noise)\n","            loss_d = (criterion(critic(real).view(-1), torch.ones(bs, device=device)*0.9) +\n","                      criterion(critic(fake.detach()).view(-1), torch.zeros(bs, device=device))) / 2\n","            critic.zero_grad(); loss_d.backward(); opt_critic.step()\n","\n","            # Generator Update\n","            loss_g = criterion(critic(fake).view(-1), torch.ones(bs, device=device))\n","            gen.zero_grad(); loss_g.backward(); opt_gen.step()\n","\n","            d_losses.append(loss_d.item()); g_losses.append(loss_g.item())\n","\n","        # End of Epoch Records\n","        avg_d, avg_g = sum(d_losses)/len(d_losses), sum(g_losses)/len(g_losses)\n","        record_to_ledger(epoch + 1, avg_d, avg_g)\n","\n","        torch.save({'epoch': epoch, 'gen_state_dict': gen.state_dict(), 'critic_state_dict': critic.state_dict(),\n","                    'opt_gen_state_dict': opt_gen.state_dict(), 'opt_critic_state_dict': opt_critic.state_dict()}, checkpoint_path)\n","\n","        if (epoch + 1) % 20 == 0:\n","            print(f\"📊 Epoch {epoch+1}/1500 | D-Loss: {avg_d:.4f} | G-Loss: {avg_g:.4f}\")\n","            with torch.no_grad():\n","                samples = gen(torch.randn(16, Z_DIM, 1, 1, device=device))\n","                utils.save_image(samples, f\"refined_sample_epoch_{epoch+1}.png\", normalize=True)\n","\n","        if (epoch + 1) % 100 == 0:\n","            torch.save(gen.state_dict(), f\"refined_gen_epoch_{epoch+1}.pth\")\n","\n","finally:\n","    tracker.stop()\n","    print(\"🏁 Session complete. Your loss curve, carbon data, and weights are safe on Drive.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"oLkyYdeJzVDj","executionInfo":{"status":"ok","timestamp":1776692548377,"user_tz":-60,"elapsed":5468784,"user":{"displayName":"antonios kelarakis","userId":"07677858474665266404"}},"outputId":"4c89fc2e-e6ce-41ef-f436-cbf0e396661e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","✅ Working in: /content/drive/MyDrive/Medical_GAN_Refined\n","🧠 Resuming from Epoch 1000\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 4.17M/4.17M [00:00<00:00, 29.4MB/s]\n","[codecarbon WARNING @ 12:11:43] Multiple instances of cod