0.026892 kWh\n","[codecarbon INFO @ 15:11:42] Energy consumed for all GPUs : 0.041409 kWh. Total GPU Power : 65.33872319497901 W\n","[codecarbon INFO @ 15:11:42] 0.074629 kWh of electricity and 0.000000 L of water were used since the beginning.\n","[codecarbon INFO @ 15:11:42] 0.011427 g.CO2eq/s mean an estimation of 360.3502941397564 kg.CO2eq/year\n"]},{"output_type":"stream","name":"stdout","text":["✅ Epoch 200 synced. Check your folder now!\n"]},{"output_type":"stream","name":"stderr","text":["[codecarbon INFO @ 15:11:57] Energy consumed for RAM : 0.006368 kWh. RAM Power : 10.0 W\n"]}]},{"cell_type":"code","source":["import torch, torch.nn as nn, torch.optim as optim\n","from torch.utils.data import DataLoader\n","from torchvision import transforms, utils\n","import medmnist, os, gc, datetime\n","from medmnist import INFO\n","from codecarbon import EmissionsTracker\n","from google.colab import drive\n","\n","# 1. CONNECT & SETUP\n","if not os.path.exists('/content/drive'):\n","    drive.mount('/content/drive')\n","\n","save_path = '/content/drive/MyDrive/Medical_WGAN_GP_Project'\n","device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","\n","# --- DEFINE MODELS\n","class Generator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.main = nn.Sequential(\n","            nn.ConvTranspose2d(100, 64*16, 4, 1, 0), nn.BatchNorm2d(64*16), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(64*16, 64*8, 3, 1, 1), nn.BatchNorm2d(64*8), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(64*8, 64*4, 3, 1, 1), nn.BatchNorm2d(64*4), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(64*4, 64*2, 3, 1, 1), nn.BatchNorm2d(64*2), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(64*2, 1, 3, 1, 1), nn.Tanh()\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","class Critic(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.main = nn.Sequential(\n","            nn.Conv2d(1, 64, 4, 2, 1), nn.LeakyReLU(0.2),\n","            nn.Conv2d(64, 128, 4, 2, 1), nn.InstanceNorm2d(128, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(128, 256, 4, 2, 1), nn.InstanceNorm2d(256, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(256, 512, 4, 2, 1), nn.InstanceNorm2d(512, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(512, 1, 4, 1, 0)\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","# 2. INITIALIZE MODELS\n","gen, critic = Generator().to(device), Critic().to(device)\n","opt_gen = optim.Adam(gen.parameters(), lr=0.00005, betas=(0.0, 0.9))\n","opt_critic = optim.Adam(critic.parameters(), lr=0.00005, betas=(0.0, 0.9))\n","\n","# ---LOAD THE SAVED WEIGHTS ---\n","START_EPOCH = 205\n","checkpoint_path = os.path.join(save_path, 'checkpoint_latest.pth')\n","\n","if os.path.exists(checkpoint_path):\n","    print(f\"🔄 Loading saved model from Epoch {START_EPOCH}...\")\n","    checkpoint = torch.load(checkpoint_path)\n","    gen.load_state_dict(checkpoint['gen_state_dict'])\n","    critic.load_state_dict(checkpoint['critic_state_dict'])\n","    opt_gen.load_state_dict(checkpoint['opt_gen_state_dict'])\n","    opt_critic.load_state_dict(checkpoint['opt_critic_state_dict'])\n","    print(\"✅ Success! Ready to continue.\")\n","else:\n","    print(\"⚠️ Checkpoint file not found. Starting from scratch instead.\")\n","    START_EPOCH = 0\n","\n","# 3. DATA & TRACKER\n","dataset = medmnist.PneumoniaMNIST(split='train', transform=transforms.Compose([\n","    transforms.Resize(64), transforms.ToTensor(), transforms.Normalize((0.5,), (0.5,))\n","]), download=True)\n","loader = DataLoader(dataset, batch_size=32, shuffle=True)\n","tracker = EmissionsTracker(output_dir=save_path)\n","tracker.start()\n","\n","# 4. RESUMED TRAINING LOOP\n","try:\n","    for epoch in range(START_EPOCH, 2500):\n","        for real, _ in loader:\n","            real = real.to(device)\n","            # (WGAN Training Logic)\n","            noise = torch.randn(real.shape[0], 100, 1, 1).to(device)\n","            fake = gen(noise)\n","            loss_d = -torch.mean(critic(real)) + torch.mean(critic(fake.detach()))\n","            critic.zero_grad(); loss_d.backward(); opt_critic.step()\n","            loss_g = -torch.mean(critic(gen(noise)))\n","            gen.zero_grad(); loss_g.backward(); opt_gen.step()\n","\n","        # SAVE CHECKPOINT EVERY 10 EPOCHS\n","        if (epoch + 1) % 10 == 0:\n","            # Save weights so we can resume again if it crashes\n","            torch.save({\n","                'gen_state_dict': gen.state_dict(),\n","                'critic_state_dict': critic.state_dict(),\n","                'opt_gen_state_dict': opt_gen.state_dict(),\n","                'opt_critic_state_dict': opt_critic.state_dict(),\n","            }, checkpoint_path)\n","\n","            # Save Image & Log\n","            with torch.no_grad():\n","                img = gen(torch.randn(16, 100, 1, 1).to(device))\n","                utils.save_image(img, f\"{save_path}/latest_progress.png\", normalize=True)\n","\n","            with open(os.path.join(save_path, 'continuous_training_log.csv'), 'a') as f:\n","                f.write(f\"{datetime.datetime.now()},{epoch+1},{loss_d.item():.4f},{loss_g.item():.4f}\\n\")\n","                f.flush(); os.fsync(f.fileno())\n","\n","            print(f\"✅ Progress saved at Epoch {epoch+1}\")\n","\n","finally:\n","    tracker.stop()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Wfxf9Ebzw6i4","outputId":"e3c7d45f-5223-4f22-bbe0-32fecd8e1c34"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n","⚠️ Checkpoint file not found. Starting from scratch instead.\n"]},{"output_type":"stream","name":"stderr","text":["100%|██████████| 4.17M/4.17M [00:01<00:00, 3.54MB/s]\n","[codecarbon WARNING @ 16:12:55] Multiple instances of