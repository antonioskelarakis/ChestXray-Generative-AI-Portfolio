ity and 0.000000 L of water were used since the beginning.\n","[codecarbon INFO @ 12:55:39] Energy consumed for RAM : 0.009865 kWh. RAM Power : 10.0 W\n","[codecarbon INFO @ 12:55:39] Delta energy consumed for CPU with constant : 0.000177 kWh, power : 42.5 W\n","[codecarbon INFO @ 12:55:39] Energy consumed for All CPU : 0.041931 kWh\n","[codecarbon INFO @ 12:55:39] Energy consumed for all GPUs : 0.063974 kWh. Total GPU Power : 64.91776854564125 W\n","[codecarbon INFO @ 12:55:39] 0.115769 kWh of electricity and 0.000000 L of water were used since the beginning.\n"]}]},{"cell_type":"code","source":["import torch\n","import torch.nn as nn\n","import torch.optim as optim\n","from torch.utils.data import DataLoader\n","from torchvision import transforms, utils\n","import medmnist\n","from medmnist import INFO\n","from codecarbon import EmissionsTracker\n","import os, gc, csv, datetime\n","from google.colab import drive\n","\n","# 1. MOUNT DRIVE AND SETUP FOLDER\n","if not os.path.exists('/content/drive'):\n","    drive.mount('/content/drive')\n","\n","save_path = '/content/drive/MyDrive/Medical_WGAN_GP_Project'\n","os.makedirs(save_path, exist_ok=True)\n","\n","# 2. HYPERPARAMETERS\n","device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","BATCH_SIZE = 32  # Safety first to avoid the 'Red' error\n","Z_DIM = 100\n","FEATURES = 64\n","LR = 0.00005\n","NUM_EPOCHS = 2500\n","CRITIC_ITERATIONS = 5\n","LAMBDA_GP = 10\n","\n","# 3. Classes\n","class Generator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.main = nn.Sequential(\n","            nn.ConvTranspose2d(Z_DIM, FEATURES*16, 4, 1, 0),\n","            nn.BatchNorm2d(FEATURES*16), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(FEATURES*16, FEATURES*8, 3, 1, 1),\n","            nn.BatchNorm2d(FEATURES*8), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(FEATURES*8, FEATURES*4, 3, 1, 1),\n","            nn.BatchNorm2d(FEATURES*4), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(FEATURES*4, FEATURES*2, 3, 1, 1),\n","            nn.BatchNorm2d(FEATURES*2), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(FEATURES*2, 1, 3, 1, 1), nn.Tanh()\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","class Critic(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        def block(in_c, out_c):\n","            return nn.Sequential(\n","                nn.utils.spectral_norm(nn.Conv2d(in_c, out_c, 4, 2, 1)),\n","                nn.InstanceNorm2d(out_c, affine=True),\n","                nn.LeakyReLU(0.2)\n","            )\n","        self.main = nn.Sequential(\n","            nn.Conv2d(1, FEATURES, 4, 2, 1), nn.LeakyReLU(0.2),\n","            block(FEATURES, FEATURES*2),\n","            block(FEATURES*2, FEATURES*4),\n","            block(FEATURES*4, FEATURES*8),\n","            nn.Conv2d(FEATURES*8, 1, 4, 1, 0)\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","# 4. GRADIENT PENALTY FUNCTION\n","def get_gp(critic, real, fake):\n","    alpha = torch.rand((real.shape[0], 1, 1, 1)).to(device)\n","    interpolated = (real * alpha + fake * (1 - alpha)).requires_grad_(True)\n","    score = critic(interpolated)\n","    grad = torch.autograd.grad(inputs=interpolated, outputs=score,\n","                               grad_outputs=torch.ones_like(score),\n","                               create_graph=True, retain_graph=True)[0]\n","    return torch.mean((grad.view(grad.shape[0], -1).norm(2, dim=1) - 1) ** 2)\n","\n","# 5. DATA AND MODEL INITIALIZATION\n","info = INFO['pneumoniamnist']\n","DataClass = getattr(medmnist, info['python_class'])\n","dataset = DataClass(split='train', transform=transforms.Compose([\n","    transforms.Resize(64), transforms.ToTensor(), transforms.Normalize((0.5,), (0.5,))\n","]), download=True)\n","loader = DataLoader(dataset, batch_size=BATCH_SIZE, shuffle=True)\n","\n","gen, critic = Generator().to(device), Critic().to(device)\n","opt_gen = optim.Adam(gen.parameters(), lr=LR, betas=(0.0, 0.9))\n","opt_critic = optim.Adam(critic.parameters(), lr=LR, betas=(0.0, 0.9))\n","\n","# 6. TRAINING LOOP\n","tracker = EmissionsTracker(output_dir=save_path)\n","tracker.start()\n","print(\"🚀 Training Started! Check your Google Drive 'Medical_WGAN_GP_Project' folder.\")\n","\n","try:\n","    for epoch in range(NUM_EPOCHS):\n","        for real, _ in loader:\n","            real = real.to(device)\n","            # Update Critic\n","            for _ in range(CRITIC_ITERATIONS):\n","                noise = torch.randn(real.shape[0], Z_DIM, 1, 1).to(device)\n","                fake = gen(noise)\n","                loss_d = -(torch.mean(critic(real)) - torch.mean(critic(fake.detach()))) + LAMBDA_GP * get_gp(critic, real, fake.detach())\n","                critic.zero_grad(); loss_d.backward(); opt_critic.step()\n","\n","            # Update Generator\n","            loss_g = -torch.mean(critic(gen(torch.randn(real.shape[0], Z_DIM, 1, 1).to(device))))\n","            gen.zero_grad(); loss_g.backward(); opt_gen.step()\n","\n","        # Clean memory\n","        torch.cuda.empty_cache()\n","        gc.collect()\n","\n","        # Save every 100 epochs\n","        if (epoch + 1) % 100 == 0:\n","            with open(os.path.join(save_path, 'training_log.csv'), 'a') as f:\n","                f.write(f\"{datetime.datetime.now()},{epoch+1},{loss_d.item()},{loss_g.item()}\\n\")\n","            with torch.no_grad():\n","                img = gen(torch.randn(16, Z_DIM, 1, 1).to(device))\n","                utils.save_image(img, f\"{save_path}/epoch_{epoch+1}.png\", normalize=True, nrow=4)\n","            print(f\"✅ Epoch {epoch+1} saved to Drive.\")\n","\n","finally:\n","    tracker.stop()\n","    print(\"Session closed.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"QXP_e9h6eB80","ou