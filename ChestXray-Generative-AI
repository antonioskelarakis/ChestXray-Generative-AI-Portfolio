,\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(FEATURES*4, FEATURES*2, 3, 1, 1),\n","            nn.BatchNorm2d(FEATURES*2), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2),\n","            nn.Conv2d(FEATURES*2, 1, 3, 1, 1), nn.Tanh()\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","class Critic(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        def block(in_c, out_c):\n","            return nn.Sequential(\n","                nn.utils.spectral_norm(nn.Conv2d(in_c, out_c, 4, 2, 1)),\n","                nn.InstanceNorm2d(out_c, affine=True),\n","                nn.LeakyReLU(0.2)\n","            )\n","        self.main = nn.Sequential(\n","            nn.Conv2d(1, FEATURES, 4, 2, 1), nn.LeakyReLU(0.2),\n","            block(FEATURES, FEATURES*2),\n","            block(FEATURES*2, FEATURES*4),\n","            block(FEATURES*4, FEATURES*8),\n","            nn.Conv2d(FEATURES*8, 1, 4, 1, 0)\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","# --- 3. WGAN-GP GRADIENT PENALTY ---\n","def get_gp(critic, real, fake):\n","    alpha = torch.rand((real.shape[0], 1, 1, 1)).to(device)\n","    interpolated = (real * alpha + fake * (1 - alpha)).requires_grad_(True)\n","    score = critic(interpolated)\n","    grad = torch.autograd.grad(inputs=interpolated, outputs=score,\n","                               grad_outputs=torch.ones_like(score),\n","                               create_graph=True, retain_graph=True)[0]\n","    return torch.mean((grad.view(grad.shape[0], -1).norm(2, dim=1) - 1) ** 2)\n","\n","# --- 4. DATA LOAD & INITIALIZATION ---\n","info = INFO['pneumoniamnist']\n","DataClass = getattr(medmnist, info['python_class'])\n","dataset = DataClass(split='train', transform=transforms.Compose([\n","    transforms.Resize(64), transforms.ToTensor(), transforms.Normalize((0.5,), (0.5,))\n","]), download=True)\n","loader = DataLoader(dataset, batch_size=64, shuffle=True)\n","\n","gen, critic = Generator().to(device), Critic().to(device)\n","opt_gen = optim.Adam(gen.parameters(), lr=LR, betas=(0.0, 0.9))\n","opt_critic = optim.Adam(critic.parameters(), lr=LR, betas=(0.0, 0.9))\n","\n","# --- 5. LOGGING SETUP  ---\n","log_path = os.path.join(save_path, 'continuous_training_log.csv')\n","if not os.path.exists(log_path):\n","    with open(log_path, 'w', newline='') as f:\n","        writer = csv.writer(f)\n","        writer.writerow(['timestamp', 'epoch', 'loss_d', 'loss_g'])\n","\n","# --- 6. CONTINUOUS TRAINING LOOP ---\n","tracker = EmissionsTracker(output_dir=save_path, project_name=\"Medical_WGAN_GP_Final\")\n","tracker.start()\n","\n","print(\"🚀 Training starting... monitor your Google Drive folder for updates.\")\n","\n","try:\n","    for epoch in range(NUM_EPOCHS):\n","        for real, _ in loader:\n","            real = real.to(device)\n","            # Update Critic\n","            for _ in range(CRITIC_ITERATIONS):\n","                fake = gen(torch.randn(real.shape[0], Z_DIM, 1, 1).to(device))\n","                loss_d = -(torch.mean(critic(real)) - torch.mean(critic(fake.detach()))) + LAMBDA_GP * get_gp(critic, real, fake.detach())\n","                critic.zero_grad(); loss_d.backward(); opt_critic.step()\n","\n","            # Update Generator\n","            loss_g = -torch.mean(critic(gen(torch.randn(real.shape[0], Z_DIM, 1, 1).to(device))))\n","            gen.zero_grad(); loss_g.backward(); opt_gen.step()\n","\n","        # Save Metrics and Images every 100 Epochs\n","        if (epoch + 1) % 100 == 0:\n","            timestamp = datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n","            with open(log_path, 'a', newline='') as f:\n","                writer = csv.writer(f)\n","                writer.writerow([timestamp, epoch + 1, loss_d.item(), loss_g.item()])\n","\n","            with torch.no_grad():\n","                img = gen(torch.randn(16, Z_DIM, 1, 1).to(device))\n","                utils.save_image(img, f\"{save_path}/sample_epoch_{epoch+1}.png\", normalize=True, nrow=4)\n","\n","            torch.save(gen.state_dict(), f\"{save_path}/wgan_gen_latest.pth\")\n","            print(f\"✅ Milestone Reached: Epoch {epoch+1} saved to Drive.\")\n","\n","except KeyboardInterrupt:\n","    print(\"⚠️ Training paused by user.\")\n","finally:\n","    tracker.stop()\n","    print(\"📁 Session Complete. All logs and CO2 data are synced to Google Drive.\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"dd-w_Dl0KYB7","outputId":"d2e5e52b-abc5-4762-c831-ec5602b06132"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["100%|██████████| 4.17M/4.17M [00:06<00:00, 617kB/s]\n","[codecarbon WARNING @ 11:56:22] Multiple instances of codecarbon are allowed to run at the same time.\n","[codecarbon INFO @ 11:56:22] [setup] RAM Tracking...\n","[codecarbon INFO @ 11:56:22] [setup] CPU Tracking...\n","[codecarbon WARNING @ 11:56:23] We saw that you have a Intel(R) Xeon(R) CPU @ 2.00GHz but we don't know it. Please contact us.\n","[codecarbon WARNING @ 11:56:23] No CPU tracking mode found. Falling back on estimation based on TDP for CPU. \n"," Linux OS detected: Please ensure RAPL files exist, and are readable, at /sys/class/powercap/intel-rapl/subsystem to measure CPU\n","\n","[codecarbon INFO @ 11:56:23] CPU Model on constant consumption mode: Intel(R) Xeon(R) CPU @ 2.00GHz\n","[codecarbon WARNING @ 11:56:23] No CPU tracking mode found. Falling back on CPU constant mode.\n","[codecarbon INFO @ 11:56:23] [setup] GPU Tracking...\n","[codecarbon INFO @ 11:56:23] Tracking Nvidia GPUs via PyNVML\n","[codecarbon INFO @ 11:56:23] The below tracking methods have been set up:\n","                RAM Tracking Method: RAM power estimation model\n","                CPU Tracking Method: global constant\n","                GPU Tracking Method: pynvml\n","            \n","[codecarbon INFO @ 11:56:23] >>> Tracker's metadata:\n","[codecarbon 