{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"gpuType":"T4"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"},"accelerator":"GPU"},"cells":[{"cell_type":"markdown","source":["Method 1: Baseline DCGAN"],"metadata":{"id":"wSyZnEbnlWd4"}},{"cell_type":"code","source":["# ==========================================\n","# 1. SETUP & DATA (PneumoniaMNIST)\n","# ==========================================\n","from google.colab import drive\n","import os\n","drive.mount('/content/drive')\n","!pip install -q medmnist codecarbon\n","\n","import torch\n","import torch.nn as nn\n","import torch.optim as optim\n","from torch.utils.data import DataLoader\n","from torchvision import transforms\n","from torchvision.utils import save_image, make_grid\n","import medmnist\n","from medmnist import INFO\n","from codecarbon import EmissionsTracker\n","\n","# folder for the 400-epoch run\n","save_path = '/content/drive/MyDrive/Medical_GAN_400'\n","if not os.path.exists(save_path): os.makedirs(save_path)\n","\n","# ==========================================\n","# 2. ARCHITECTURE (DCGAN)- Baseline Method 1\n","# ==========================================\n","class Generator(nn.Module):\n","    def __init__(self, z_dim, img_channels, features_g):\n","        super(Generator, self).__init__()\n","        self.gen = nn.Sequential(\n","            nn.ConvTranspose2d(z_dim, features_g * 8, 4, 1, 0),\n","            nn.BatchNorm2d(features_g * 8), nn.ReLU(),\n","            nn.ConvTranspose2d(features_g * 8, features_g * 4, 4, 2, 1),\n","            nn.BatchNorm2d(features_g * 4), nn.ReLU(),\n","            nn.ConvTranspose2d(features_g * 4, features_g * 2, 4, 2, 1),\n","            nn.BatchNorm2d(features_g * 2), nn.ReLU(),\n","            nn.ConvTranspose2d(features_g * 2, features_g, 4, 2, 1),\n","            nn.BatchNorm2d(features_g), nn.ReLU(),\n","            nn.ConvTranspose2d(features_g, img_channels, 4, 2, 1),\n","            nn.Tanh(),\n","        )\n","    def forward(self, x): return self.gen(x)\n","\n","class Critic(nn.Module):\n","    def __init__(self, img_channels, features_d):\n","        super(Critic, self).__init__()\n","        self.critic = nn.Sequential(\n","            nn.Conv2d(img_channels, features_d, 4, 2, 1), nn.LeakyReLU(0.2),\n","            nn.Conv2d(features_d, features_d * 2, 4, 2, 1),\n","            nn.InstanceNorm2d(features_d * 2, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(features_d * 2, features_d * 4, 4, 2, 1),\n","            nn.InstanceNorm2d(features_d * 4, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(features_d * 4, features_d * 8, 4, 2, 1),\n","            nn.InstanceNorm2d(features_d * 8, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(features_d * 8, 1, 4, 2, 0),\n","        )\n","    def forward(self, x): return self.critic(x)\n","\n","# ==========================================\n","# 3. TRAINING CONFIGURATION\n","# ==========================================\n","device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","LR = 0.0002\n","BATCH_SIZE = 64\n","Z_DIM = 100\n","NUM_EPOCHS = 400\n","FEATURES = 64\n","\n","# Load full training set (4,708 images)\n","info = INFO['pneumoniamnist']\n","DataClass = getattr(medmnist, info['python_class'])\n","transform = transforms.Compose([\n","    transforms.Resize(64), transforms.ToTensor(), transforms.Normalize((0.5,), (0.5,)),\n","])\n","train_dataset = DataClass(split='train', transform=transform, download=True)\n","loader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True)\n","\n","gen = Generator(Z_DIM, 1, FEATURES).to(device)\n","critic = Critic(1, FEATURES).to(device)\n","opt_gen = optim.Adam(gen.parameters(), lr=LR, betas=(0.5, 0.999))\n","opt_critic = optim.Adam(critic.parameters(), lr=LR, betas=(0.5, 0.999))\n","criterion = nn.BCEWithLogitsLoss()\n","tracker = EmissionsTracker(output_dir=save_path)\n","\n","\n","print(f\"🚀 Training for {NUM_EPOCHS} epochs on {device}...\")\n","tracker.start()\n","\n","try:\n","    for epoch in range(NUM_EPOCHS):\n","        for batch_idx, (real, _) in enumerate(loader):\n","            real = real.to(device)\n","            cur_batch_size = real.shape[0]\n","\n","            # --- Train Critic ---\n","            noise = torch.randn(cur_batch_size, Z_DIM, 1, 1).to(device)\n","            fake = gen(noise)\n","            critic_real = critic(real).reshape(-1)\n","            # LABEL SMOOTHING (0.9 instead of 1.0)\n","            loss_critic_real = criterion(critic_real, torch.ones_like(critic_real) * 0.9)\n","            critic_fake = critic(fake.detach()).reshape(-1)\n","            loss_critic_fake = criterion(critic_fake, torch.zeros_like(critic_fake))\n","            loss_critic = (loss_critic_real + loss_critic_fake) / 2\n","\n","            critic.zero_grad()\n","            loss_critic.backward()\n","            opt_critic.step()\n","\n","            # --- Train Generator ---\n","            output = critic(fake).reshape(-1)\n","            loss_gen = criterion(output, torch.ones_like(output))\n","\n","            gen.zero_grad()\n","            loss_gen.backward()\n","            opt_gen.step()\n","\n","        # Save Progress every 25 epochs\n","        if (epoch + 1) % 25 == 0:\n","            print(f\"💾 Saving Epoch {epoch+1} to Drive...\")\n","            torch.save(gen.state_dict(), f\"{save_path}/gen_400_epoch_{epoch+1}.pth\")\n","            with torch.no_grad():\n","                samples = gen(torch.randn(16, Z_DIM, 1, 1).to(device))\n","                save_image(samples, f\"{save_path}/progress_{epoch+1}.png\", normalize=True)\n","\n","finally:\n","    emissions = tracker.stop()\n","    print(f\"🌍 Final Carbon Footprint: {emissions:.6f} kg CO2\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"g54HW903MUKP","outputId":"0b9deae7-02f6-4544-e33e-9d59504f692b"},"execution_count":null,"outputs":[{"output_type":"stream","name":"std