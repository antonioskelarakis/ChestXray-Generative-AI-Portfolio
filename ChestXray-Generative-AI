le(scale_factor=2), nn.Conv2d(64*2, 1, 3, 1, 1), nn.Tanh()\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","class Critic(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.main = nn.Sequential(\n","            nn.Conv2d(1, 64, 4, 2, 1), nn.LeakyReLU(0.2),\n","            nn.Conv2d(64, 128, 4, 2, 1), nn.InstanceNorm2d(128, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(128, 256, 4, 2, 1), nn.InstanceNorm2d(256, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(256, 512, 4, 2, 1), nn.InstanceNorm2d(512, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(512, 1, 4, 1, 0)\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","# 3. SETUP DATA\n","device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","dataset = medmnist.PneumoniaMNIST(split='train', transform=transforms.Compose([\n","    transforms.Resize(64), transforms.ToTensor(), transforms.Normalize((0.5,), (0.5,))\n","]), download=True)\n","loader = DataLoader(dataset, batch_size=32, shuffle=True)\n","\n","gen, critic = Generator().to(device), Critic().to(device)\n","opt_gen = optim.Adam(gen.parameters(), lr=0.00005, betas=(0.0, 0.9))\n","opt_critic = optim.Adam(critic.parameters(), lr=0.00005, betas=(0.0, 0.9))\n","\n","# 4. TRAINING WITH INSTANT SAVING\n","tracker = EmissionsTracker(output_dir=save_path)\n","tracker.start()\n","\n","print(\"🚀 Starting... You will see 'latest_progress.png' in Drive within 2 minutes.\")\n","\n","try:\n","    for epoch in range(2500):\n","        for real, _ in loader:\n","            real = real.to(device)\n","            # (WGAN Training Logic...)\n","            noise = torch.randn(real.shape[0], 100, 1, 1).to(device)\n","            fake = gen(noise)\n","            loss_d = -torch.mean(critic(real)) + torch.mean(critic(fake.detach()))\n","            critic.zero_grad(); loss_d.backward(); opt_critic.step()\n","            loss_g = -torch.mean(critic(gen(noise)))\n","            gen.zero_grad(); loss_g.backward(); opt_gen.step()\n","\n","        # EVERY 5 EPOCHS: Force data to show up in Drive\n","        if (epoch + 1) % 5 == 0:\n","            # Overwrite one image to save space\n","            with torch.no_grad():\n","                img = gen(torch.randn(16, 100, 1, 1).to(device))\n","                utils.save_image(img, f\"{save_path}/latest_progress.png\", normalize=True)\n","\n","            # Append to log\n","            log_path = os.path.join(save_path, 'continuous_training_log.csv')\n","            with open(log_path, 'a') as f:\n","                f.write(f\"{datetime.datetime.now()},{epoch+1},{loss_d.item():.4f},{loss_g.item():.4f}\\n\")\n","                f.flush()\n","                os.fsync(f.fileno()) # Force Google Drive to sync NOW\n","\n","            print(f\"✅ Epoch {epoch+1} synced. Check your folder now!\")\n","            torch.cuda.empty_cache()\n","\n","finally:\n","    tracker.stop()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"e_MPTXO0vIYb","outputId":"54f45035-a340-4992-8c8e-a5a30d176419"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["100%|██████████| 4.17M/4.17M [00:07<00:00, 577kB/s]\n","[codecarbon WARNING @ 14:33:40] Multiple instances of codecarbon are allowed to run at the same time.\n","[codecarbon INFO @ 14:33:40] [setup] RAM Tracking...\n","[codecarbon INFO @ 14:33:40] [setup] CPU Tracking...\n","[codecarbon WARNING @ 14:33:42] We saw that you have a Intel(R) Xeon(R) CPU @ 2.00GHz but we don't know it. Please contact us.\n","[codecarbon WARNING @ 14:33:42] No CPU tracking mode found. Falling back on estimation based on TDP for CPU. \n"," Linux OS detected: Please ensure RAPL files exist, and are readable, at /sys/class/powercap/intel-rapl/subsystem to measure CPU\n","\n","[codecarbon INFO @ 14:33:42] CPU Model on constant consumption mode: Intel(R) Xeon(R) CPU @ 2.00GHz\n","[codecarbon WARNING @ 14:33:42] No CPU tracking mode