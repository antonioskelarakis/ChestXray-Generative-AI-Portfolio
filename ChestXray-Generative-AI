p install medmnist codecarbon\n","\n","import torch, torch.nn as nn, torch.optim as optim\n","from torch.utils.data import DataLoader\n","from torchvision import transforms, utils\n","import medmnist, os, gc, datetime\n","from codecarbon import EmissionsTracker\n","from google.colab import drive\n","\n","# 2. MOUNT DRIVE\n","try:\n","    drive.mount('/content/drive', force_remount=True)\n","    print(\"✅ Drive Mounted successfully.\")\n","except:\n","    print(\"❌ Drive mount failed. Please check the popup window.\")\n","\n","save_path = '/content/drive/MyDrive/Medical_WGAN_GP_Project'\n","checkpoint_path = os.path.join(save_path, 'checkpoint_latest.pth')\n","device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","\n","# 3. MODELS\n","class Generator(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.main = nn.Sequential(\n","            nn.ConvTranspose2d(100, 1024, 4, 1, 0), nn.BatchNorm2d(1024), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(1024, 512, 3, 1, 1), nn.BatchNorm2d(512), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(512, 256, 3, 1, 1), nn.BatchNorm2d(256), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(256, 128, 3, 1, 1), nn.BatchNorm2d(128), nn.ReLU(True),\n","            nn.Upsample(scale_factor=2), nn.Conv2d(128, 1, 3, 1, 1), nn.Tanh()\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","class Critic(nn.Module):\n","    def __init__(self):\n","        super().__init__()\n","        self.main = nn.Sequential(\n","            nn.Conv2d(1, 64, 4, 2, 1), nn.LeakyReLU(0.2),\n","            nn.Conv2d(64, 128, 4, 2, 1), nn.InstanceNorm2d(128, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(128, 256, 4, 2, 1), nn.InstanceNorm2d(256, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(256, 512, 4, 2, 1), nn.InstanceNorm2d(512, affine=True), nn.LeakyReLU(0.2),\n","            nn.Conv2d(512, 1, 4, 1, 0)\n","        )\n","    def forward(self, x): return self.main(x)\n","\n","gen, critic = Generator().to(device), Critic().to(device)\n","opt_gen = optim.Adam(gen.parameters(), lr=0.00005, betas=(0.0, 0.9))\n","opt_critic = optim.Adam(critic.parameters(), lr=0.00005, betas=(0.0, 0.9))\n","\n","# 4. LOAD STATE FROM EPOCH 640\n","if os.path.exists(checkpoint_path):\n","    print(\"🔄 Loading checkpoint from Drive...\")\n","    checkpoint = torch.load(checkpoint_path)\n","    gen.load_state_dict(checkpoint['gen_state_dict'])\n","    critic.load_state_dict(checkpoint['critic_state_dict'])\n","    opt_gen.load_state_dict(checkpoint['opt_gen_state_dict'])\n","    opt_critic.load_state_dict(checkpoint['opt_critic_state_dict'])\n","    start_epoch = checkpoint.get('epoch', 640)\n","    print(f\"✅ Success! Resuming from Epoch {start_epoch}\")\n","else:\n","    print(\"⚠️ No checkpoint found. Check your Drive path.\")\n","    start_epoch = 640\n","\n","# 5. DATASET & TRACKER\n","dataset = medmnist.PneumoniaMNIST(split='train', transform=transforms.Compose([\n","    transforms.Resize(64), transforms.ToTensor(), transforms.Normalize((0.5,), (0.5,))\n","]), download=True)\n","loader = DataLoader(dataset, batch_size=32, shuffle=True)\n","tracker = EmissionsTracker(output_dir=save_path)\n","tracker.start()\n","\n","# 6. TRAINING LOOP\n","try:\n","    for epoch in range(start_epoch, 2501):\n","        for real, _ in loader:\n","            real = real.to(device)\n","            noise = torch.randn(real.shape[0], 100, 1, 1).to(device)\n","            fake = gen(noise)\n","            loss_d = -torch.mean(critic(real)) + torch.mean(critic(fake.detach()))\n","            critic.zero_grad(); loss_d.backward(); opt_critic.step()\n","            loss_g = -torch.mean(critic(gen(noise)))\n","            gen.zero_grad(); loss_g.backward(); opt_gen.step()\n","\n","        if (epoch + 1) % 10 == 0:\n","            torch.save({\n","                'epoch': epoch + 1,\n","                'gen_state_dict': gen.state_dict(),\n","                'critic_state_dict': critic.state_dict(),\n","                'opt_gen_state_dict': opt_gen.state_dict(),\n","                'opt_critic_state_dict': opt_critic.state_dict(),\n","            }, checkpoint_path)\n","\n","            with torch.no_grad():\n","                img = gen(torch.randn(16, 100, 1, 1).to(device))\n","                utils.save_image(img, f\"{save_path}/latest_progress.png\", normalize=True)\n","\n","            with open(os.path.join(save_path, 'continuous_training_log.csv'), 'a') as f:\n","                f.write(f\"{datetime.datetime.now()},{epoch+1},{loss_d.item():.4f},{loss_g.item():.4f}\\n\")\n","                f.flush(); os.fsync(f.fileno())\n","\n","            print(f\"💾 Milestone Saved: Epoch {epoch+1}\")\n","\n","finally:\n","    tracker.stop()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"MVU4L3Z5Vwv5","outputId":"235e768d-e28b-4a21-9727-c84d584eb29e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Requirement already satisfied: medmnist in /usr/local/lib/python3.12/dist-packages (3.0.2)\n","Requirement already satisfied: codecarbon in /usr/local/lib/python3.12/dist-packages (3.2.6)\n","Requirement already satisfied: numpy in /usr/local/lib/python3.12/dist-packages (from medmnist) (2.0.2)\n","Requirement already satisfied: pandas in /usr/local/lib/python3.12/dist-packages (from medmnist) (2.2.2)\n","Requirement already satisfied: scikit-learn in /usr/local/lib/python3.12/dist-packages (from medmnist) (1.6.1)\n","Requirement already satisfied: scikit-image in /usr/local/lib/python3.12/dist-packages (from medmnist) (0.25.2)\n","Requirement already satisfied: tqdm in /usr/local/lib/python3.12/dist-packages (from medmnist) (4.67.3)\n","Requirement already satisfied: Pillow in /usr/local/lib/python3.12/dist-packages (from medmnist) (11.3.0)\n","Requirement already satisfied: fire in /usr/local/lib/python3.12/dist-packages (from medmnist)